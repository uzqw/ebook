POCKETBASE_HOST=127.0.0.1
POCKETBASE_PORT=8090
POCKETBASE_DATA_DIR=.local/pb_data
PB_SUPERUSER_EMAIL=admin@reader.local
PB_SUPERUSER_PASSWORD=ebook-reader-admin-123
APP_USER_NAME=Reader Demo User
APP_USER_EMAIL=demo@reader.local
APP_USER_PASSWORD=ebook-reader-user-123
VITE_POCKETBASE_URL=

# PDF 阅读页图片渲染清晰度，默认 220；可设 72-360，越高清越慢且图片越大
PDF_RENDER_DPI=220

# EPUB 渲染中文/CJK 字体。留空时后端会尝试 DroidSansFallback 和 Noto CJK 常见路径。
# 如果部署环境 EPUB 图片缺中文，安装 CJK 字体并设置这个路径。
EPUB_RENDER_FONT=
